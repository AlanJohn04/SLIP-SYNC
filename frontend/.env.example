# Slip-Sync Frontend Environment Variables Template
# Copy this file to '.env' or '.env.local' and populate with your own values

# Firebase Client Configuration (Used for user sign-in and session verification)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# FastAPI Backend Base URL (Fallback: http://localhost:5000/api)
VITE_API_BASE_URL=http://localhost:5000/api
